            "authLevel": "Authenticated"
          },
          {
            "method": "POST",
            "route": "/api/sales",
            "name": "Create New Sale",
            "authLevel": "Authenticated"
          },
          {
            "method": "PUT",
            "route": "/api/sales/:id",
            "name": "Update Existing Sale",
            "authLevel": "Authenticated"
          },
          {
            "method": "DELETE",
            "route": "/api/sales/:id",
            "name": "Delete Sale",
            "authLevel": "Authenticated"
          }
        ]
      }
