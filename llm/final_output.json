          },
          {
            "method": "GET",
            "route": "/api/users/:id",
            "name": "Get User Details",
            "authLevel": "Authenticated"
          }
        ]
      },
      {
        "name": "SalesGateway",
        "responsibility": "Main API handling user management, sales pipeline, analytics, and reporting.",
